## Copy this file to android/keystore.properties and fill real values.
## Do NOT commit android/keystore.properties.

# Absolute path example (Windows):
# storeFile=D:/keys/qfl-release.jks
#
# Relative path examples:
# storeFile=release/akey.jks      (resolved from android/)
# storeFile=akey.jks              (resolved from android/app/ as fallback)

storeFile=D:/path/to/your/release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
